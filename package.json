{
    "name":  "stellar-wallet-helper",
    "version":  "1.0.0",
    "description":  "Professional SDK for the Stellar Ecosystem",
    "main":  "dist/index.js",
    "types":  "dist/index.d.ts",
    "scripts":  {
                    "build":  "tsc",
                    "test":  "jest",
                    "lint":  "eslint src --ext .ts",
                    "format":  "prettier --write \"src/**/*.ts\""
                },
    "dependencies":  {
                         "@stellar/stellar-sdk":  "^15.1.0",
                         "axios":  "^1.6.0"
                     },
    "devDependencies":  {
                            "typescript":  "^5.0.0",
                            "@types/node":  "^20.0.0",
                            "jest":  "^29.5.0",
                            "@types/jest":  "^29.5.0",
                            "ts-jest":  "^29.1.0",
                            "eslint":  "^8.40.0",
                            "prettier":  "^2.8.8"
                        },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": ["**/tests/**/*.test.ts"]
    },
    "private":  true,
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/sharif-stellar-tools/stellar-wallet-helper.git"
                   }
}
